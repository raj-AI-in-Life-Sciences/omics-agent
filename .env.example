# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# API keys (only the one matching LLM_PROVIDER is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=omics-agent

# Langfuse (optional alternative to LangSmith)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Vector backend: "faiss" (default) or "pgvector"
VECTOR_BACKEND=faiss

# PostgreSQL (only needed if VECTOR_BACKEND=pgvector)
DATABASE_URL=postgresql://omics:omicspass@localhost:5432/omicsdb

# Model cache dir (Geneformer downloaded here on first use)
MODEL_CACHE_DIR=./model_cache

# Survival model
SURVIVAL_EVAL_TIMES=12,24,36,48,60   # months

# Conformal prediction
CONFORMAL_ALPHA=0.10

# FAISS
FAISS_INDEX_PATH=data/faiss_index/patients.faiss
FAISS_META_DB_PATH=data/faiss_index/meta.db

# Embedding cache
EMBEDDING_CACHE_PATH=data/processed/embeddings.h5
